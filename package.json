{
  "name": "civretro-tools",
  "version": "0.1.0",
  "private": true,
  "description": "All-TypeScript CivRetro tooling — schemas, NDJSON exporter, save parser, and CDP game launcher.",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "check": "biome check",
    "fix": "biome check --write",
    "test": "vitest run --reporter=verbose",
    "build": "tsc -b shared/types shared/exporter shared/parser shared/launcher",
    "export": "tsx shared/exporter/src/cli.ts",
    "parse": "tsx shared/parser/src/cli.ts",
    "launch": "tsx shared/launcher/src/cli.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
